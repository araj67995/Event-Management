<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Page</title>
    <link rel="stylesheet" href="css/admin.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
  <body>
    <!-- admin dashboard -->

    <!-- top -->
    <div class="top">
      <p>Admin Dashboard</p>
      <a href="login.html" class="logout">Logout</a>
    </div>

    <!-- main -->
    <div class="main">
      <h2>Welcome, Admin!</h2>
      <p>Here you can manage users, events, and bookings.</p>
    </div>

    <!-- action card  -->
     <div class="action">
        <!-- option to select -->
        <div class="option">
            <button class="tab-btn active" data-target="event-panel">Events</button>
            <button class="tab-btn" data-target="user-panel">Users</button>
            <button class="tab-btn" data-target="booking-panel">Bookings</button>
            <button class="tab-btn" data-target="revenue-panel">Revenue</button>
        </div>
       
        <!-- action that will preform -->
         <!-- 1 events -->
          <div class="events active panel" id="event-panel">
            <div class="event-options">
                <button class="sub-tab active" onclick="UpcomingEvent(this)">Upcoming Events</button>
                <button class="sub-tab" onclick="PastEvent(this)">Past Events</button>
            </div>

            <!-- upcoming event -->
            <div class="upcoming-events" id="upcoming">
                 <table>
                    <tr>
                        <th>Event Name</th>
                        <th>Event Type</th> 
                        <th>Event Location</th>
                        <th>Event Date</th>
                        <th>Detail</th>
                    </tr>
                    <tr data-visibility="Private" data-ticket="200" data-details="Annual private event in Patna.">
                        <td>Annual</td>
                        <td>Private</td>
                        <td>patna</td>
                        <td>05/60/26</td>
                        <td><button class="view-btn" onclick="openUpcomingPopup(this)"><i class="fa-solid fa-eye"></i></button></td>
                    </tr>
                    <tr data-visibility="Public" data-ticket="500" data-details="Annual public event in Patna.">
                        <td>Annual</td>
                        <td>Private</td>
                        <td>patna</td>
                        <td>05/60/26</td>
                        <td><button class="view-btn" onclick="openUpcomingPopup(this)"><i class="fa-solid fa-eye"></i></button></td>
                    </tr>
                 </table>
            </div>

            <!-- Past Event -->
            <div class="past-events" id="past" style="display: none;">
                 <table>
                    <tr>
                        <th>Event Name</th>
                        <th>Event Type</th> 
                        <th>Event Location</th>
                        <th>Event Date</th>
                        <th>Due</th>
                        <th>Details</th>
                    </tr>
                    <tr>
                        <td>Annual</td>
                        <td>Private</td>
                        <td>patna</td>
                        <td>05/60/26</td>
                        <td>50000</td>
                         <td><button class="view-btn" onclick="openPastPopup(this)"><i class="fa-solid fa-eye"></i></button></td>
                    </tr>
                    <tr>
                        <td>Annual</td>
                        <td>Private</td>
                        <td>patna</td>
                        <td>05/60/26</td>
                        <td>500060</td>
                        <td><button class="view-btn" onclick="openPastPopup(this)"><i class="fa-solid fa-eye"></i></button></td>
                    </tr>
                 </table>
            </div>
          </div>

          <!-- user details  -->
           <div class="user-detail panel" id="user-panel">
            <div class="search">
                <input type="text" name="search" placeholder="Enter the name" required>
                <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
            <table>
                <tr>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Events</th>
                    <th>Due</th>
                </tr>
                <tr>
                    <td>AdityA</td>
                    <td>88888888</td>
                    <td>6</td>
                    <td>82100</td>
                </tr>
                  <tr>
                    <td>AdityA</td>
                    <td>88888888</td>
                    <td>6</td>
                    <td>82100</td>
                </tr>
            </table>
           </div>

           <!-- BooKings -->
            <div class="booking-detail panel" id="booking-panel">
                <div class="booking-selecter">
                    <button class="sub-tab active" onclick="PendingBooking(this)">Pending Booking</button>
                    <button class="sub-tab" onclick="QuickBook(this)">Quick Book</button>
                </div>

                <!-- Pending Booking -->
                 <div class="pending-bookings" id="pending-bookings">
                    <table>
                        <tr>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                        <tr data-email="aditya@example.com" data-event-name="Wedding Ceremony" data-event-type="wedding" data-event-location="Patna" data-visibility="Private" data-ticket="Yes" data-ticket-price="1500" data-total-cost="250000" data-details="Pending booking request for a wedding ceremony.">
                            <td>Aditya</td>
                            <td>441121515</td>
                            <td>05/86/26</td>
                            <td><button class="view-btn" onclick="openBookingPopup(this)"><i class="fa-solid fa-eye"></i></button></td>
                        </tr>
                        <tr data-email="aditya2@example.com" data-event-name="Conference Meet" data-event-type="conference" data-event-location="Patna" data-visibility="Public" data-ticket="No" data-total-cost="120000" data-details="Pending booking request for a conference.">
                            <td>Aditya</td>
                            <td>441121515</td>
                            <td>05/86/26</td>
                            <td><button class="view-btn" onclick="openBookingPopup(this)"><i class="fa-solid fa-eye"></i></button></td>
                        </tr>
                    </table>
                 </div>

                 <!-- Quick Booking -->
                 <div class="quick-book" id="quick-book" style="display: none;">
                    <label for="name">Name</label>
                    <input type="text" name="name" required value="">

                    <label for="contact">Phone no.</label>
                    <input type="number" name="contact" value="" required>

                    <label for="email">Email</label>
                    <input type="email" name="email" value="" required>

                    <label for="event-name">Event Name</label>
                    <input type="text" id="evnt-name" name="event-name" required>

                     <label for="event-type">Event Type:</label>
                        <select id="event-type" name="event-type" required>
                            <option value="">Select an event type</option>
                            <option value="conference">Conference</option>
                            <option value="wedding">Wedding</option>
                            <option value="party">Party</option>
                            <option value="concert">Concert</option>
                        </select>

                        <label for="event-location">Event Location:</label>
                        <input type="text" id="event-location" name="event-location" required>

                        <label for="event-date">Event Date:</label>
                        <input type="date" id="event-date" name="event-date" required>

                        <fieldset class="option-group">
                            <legend>Visibility</legend>
                            <div class="choice-row">
                                <label class="choice-card">
                                    <input type="radio" name="visibility" value="Public">
                                    <span>Public</span>
                                </label>
                                <label class="choice-card">
                                    <input type="radio" name="visibility" value="Private">
                                    <span>Private</span>
                                </label>
                            </div>
                        </fieldset>

                        <fieldset class="option-group">
                            <legend>Ticket</legend>
                            <div class="choice-row">
                                <label class="choice-card">
                                    <input type="radio" name="ticket" value="Yes">
                                    <span>Yes</span>
                                </label>
                                <label class="choice-card">
                                    <input type="radio" name="ticket" value="No">
                                    <span>No</span>
                                </label>
                            </div>
                        </fieldset>

                        <div class="ticket-price-field" id="quick-ticket-price-field">
                            <label for="quick-ticket-price">Ticket Price</label>
                            <input type="number" id="quick-ticket-price" name="ticket-price" min="0" placeholder="Enter ticket price">
                        </div>

                        <label for="quick-total-cost">Total Cost</label>
                        <input type="number" id="quick-total-cost" name="total-cost" min="0" placeholder="Enter total event cost" required>

                        <label for="advance-booking-cost">Advance</label>
                        <input type="number" id="advance-booking-cost" name="advance-cost" min="0" placeholder="Advance Paid Amount" required>

                        <label for="event-details">Event Details:</label>
                        <textarea id="event-details" name="event-details" rows="4" required></textarea>

                        <button type="">Book</button>
                 </div>
            </div>

            <!-- Revenue -->
            <div class="revenue panel" id="revenue-panel">
                <div class="select-month">
                    <input type="month" id="revenue-month" name="month" required>
                    <button type="button" onclick="updateRevenueDashboard()">Search</button>
                </div>
                <div class="revenue-summary">
                    <div>
                        <span>Net Profit</span>
                        <strong id="net-profit">Rs. 0</strong>
                        <small id="profit-note">After expenses</small>
                    </div>
                    <div>
                        <span>Outstanding Due</span>
                        <strong id="total-due">Rs. 0</strong>
                        <small>Pending client payments</small>
                    </div>
                    <div>
                        <span>Loss / Leakage</span>
                        <strong id="total-loss">Rs. 0</strong>
                        <small>Cancellation and extra cost</small>
                    </div>
                </div>

               <div class="details revenue-metrics">
                <p><strong>Total Events</strong><span id="total-events">0</span></p>
                <p><strong>Pending Events</strong><span id="pending-events">0</span></p>
                <p><strong>Completed Events</strong><span id="completed-events">0</span></p>
                <p><strong>Cancelled Events</strong><span id="cancelled-events">0</span></p>
                <p><strong>Total Revenue</strong><span id="total-revenue">Rs. 0</span></p>
                <p><strong>Collected Amount</strong><span id="collected-amount">Rs. 0</span></p>
                <p><strong>Vendor Expense</strong><span id="vendor-expense">Rs. 0</span></p>
                <p><strong>Venue Cost</strong><span id="venue-cost">Rs. 0</span></p>
                <p><strong>Ticket Sales</strong><span id="ticket-sales">Rs. 0</span></p>
                <p><strong>Avg. Event Value</strong><span id="average-event-value">Rs. 0</span></p>
               </div>

                <div class="finance-board">
                    <div class="chart-panel">
                        <div class="section-heading">
                            <h3>Profit, Loss & Due Graph</h3>
                            <p id="chart-month-label">Current month overview</p>
                        </div>
                        <canvas id="revenue-chart" width="760" height="320"></canvas>
                        <div class="chart-legend">
                            <span><i class="legend-revenue"></i>Revenue</span>
                            <span><i class="legend-expense"></i>Expense</span>
                            <span><i class="legend-profit"></i>Profit</span>
                            <span><i class="legend-loss"></i>Loss</span>
                            <span><i class="legend-due"></i>Due</span>
                        </div>
                    </div>

                    <div class="finance-table">
                        <div class="section-heading">
                            <h3>Event Finance Breakdown</h3>
                            <p>Track payment health by event type</p>
                        </div>
                        <table>
                            <tr>
                                <th>Event Type</th>
                                <th>Bookings</th>
                                <th>Collected</th>
                                <th>Due</th>
                                <th>Status</th>
                            </tr>
                            <tr>
                                <td>Wedding</td>
                                <td>12</td>
                                <td>Rs. 18L</td>
                                <td>Rs. 4L</td>
                                <td><span class="status-pill status-good">Good</span></td>
                            </tr>
                            <tr>
                                <td>Conference</td>
                                <td>9</td>
                                <td>Rs. 11L</td>
                                <td>Rs. 2L</td>
                                <td><span class="status-pill status-watch">Watch</span></td>
                            </tr>
                            <tr>
                                <td>Concert</td>
                                <td>4</td>
                                <td>Rs. 9L</td>
                                <td>Rs. 5L</td>
                                <td><span class="status-pill status-risk">Risk</span></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
     </div>

     <!-- Pop up for pending Bookings -->
      <div class="popup booking-popup" id="booking-popup">
         <button class="popup-close" type="button" onclick="closeBookingPopup()" aria-label="Close booking popup">X</button>
         <label for="booking-name">Name</label>
                    <input type="text" id="booking-name" name="name" required value="">

                    <label for="booking-contact">Contact</label>
                    <input type="number" id="booking-contact" name="contact" value="" required>

                    <label for="booking-email">Email</label>
                    <input type="email" id="booking-email" name="email" value="" required>

                    <label for="booking-event-name">Event Name</label>
                    <input type="text" id="booking-event-name" name="event-name" required>

                     <label for="booking-event-type">Event Type:</label>
                        <select id="booking-event-type" name="event-type" required>
                            <option value="">Select an event type</option>
                            <option value="conference">Conference</option>
                            <option value="wedding">Wedding</option>
                            <option value="party">Party</option>
                            <option value="concert">Concert</option>
                        </select>

                        <label for="booking-event-location">Event Location:</label>
                        <input type="text" id="booking-event-location" name="event-location" required>

                        <label for="booking-event-date">Event Date:</label>
                        <input type="text" id="booking-event-date" name="event-date" required>

                        <label>Visibility</label>
                        <div class="radio-row">
                            <input type="radio" name="booking-visibility" value="Public">Public
                            <input type="radio" name="booking-visibility" value="Private">Private
                        </div>

                        <label>Ticket</label>
                        <div class="radio-row">
                            <input type="radio" name="booking-ticket" value="Yes">Yes 
                            <input type="radio" name="booking-ticket" value="No">No
                        </div>

                        <div class="ticket-price-field" id="booking-ticket-price-field">
                            <label for="booking-ticket-price">Ticket Price</label>
                            <input type="number" id="booking-ticket-price" name="ticket-price" min="0" placeholder="Enter ticket price">
                        </div>

                        <label for="booking-total-cost">Total Cost</label>
                        <input type="number" id="booking-total-cost" name="total-cost" min="0" placeholder="Enter total event cost" required>

                        <label for="advance-booking-cost">Advance</label>
                        <input type="number" id="advance-booking-cost" name="advance-cost" min="0" placeholder="Advance Paid Amount" required>

                        <label for="booking-event-details">Event Details:</label>
                        <textarea id="booking-event-details" name="event-details" rows="4" required></textarea>

                        <button class="cancel-btn" onclick="closeBookingPopup()">Cancel</button>
                        <button>Confirm</button>
      </div>

      <div class="popup-overlay" id="popup-overlay" onclick="closeAllPopups()"></div>

      <!-- pop up for up comming event -->
       <div class="upcoming-popup" id="upcoming-popup">
        <button class="popup-close" type="button" onclick="closeUpcomingPopup()" aria-label="Close upcoming event popup">X</button>
        <h2 id="popup-event-name">Event Name</h2>
        <p><strong>Type:</strong> <span id="popup-event-type"></span></p>
        <p><strong>Location:</strong> <span id="popup-event-location"></span></p>
        <p><strong>Date:</strong> <span id="popup-event-date"></span></p>
        <input type="date" id="popup-date-input" name="date" value=""><button>Change</button> 
        <p><strong>Visibility:</strong> <span id="popup-event-visibility"></span></p>
        <p><strong>Ticket: </strong><span id="popup-event-ticket"></span></p>
        <p><strong>Details: </strong><span id="popup-event-details"></span></p>
        <div class="popup-actions">
            <button class="cancel-btn" type="button" onclick="showUpcomingAction('cancel')">Cancel Event</button>
            <button type="button" onclick="showUpcomingAction('complete')">Mark Complete</button>
        </div>

        <div class="upcoming-action-panel" id="cancel-event-panel">
            <h3>Cancellation Details</h3>
            <label for="cancellation-charge">Cancellation Charge</label>
            <input type="number" id="cancellation-charge" min="0" placeholder="Enter cancellation charge">

            <label for="cancellation-loss">Loss Amount</label>
            <input type="number" id="cancellation-loss" min="0" placeholder="Enter total loss">

            <label for="cancellation-reason">Reason</label>
            <textarea id="cancellation-reason" rows="3" placeholder="Write cancellation reason"></textarea>

            <button class="cancel-btn" type="button">Confirm Cancellation</button>
        </div>

        <div class="upcoming-action-panel" id="complete-event-panel">
            <h3>Completion Details</h3>

            <label for="collectedAmount">Collected Amount</label>
            <input type="number" id="collectedAmount" min="0" placeholder="Enter Collected Amount" required>

            <label for="venderExpense">Vender Expense</label>
            <input type="number" id="venderExpense" min="0" placeholder="Enter Vender Expense" required>

            <label for="venueCost">Venue Cost</label>
            <input type="number" id="venueCost" min="0" placeholder="Enter Venue Cost">

            <label for="ticketSale">Tickets</label>
            <input type="number" id="ticketSale" min="0" placeholder="No. of ticket sale">

            <label for="event-images">Upload Event Images</label>
            <input type="file" id="event-images" accept="image/*" multiple>

            <label for="completion-note">Completion Note</label>
            <textarea id="completion-note" rows="3" placeholder="Add a short completion note"></textarea>

            <button type="button">Save Completed Event</button>
        </div>
       </div>

       <!-- past Event popup -->
        <div class="past-popup upcoming-action-panel" id="past-popup">
        <button class="popup-close" type="button" onclick="closePastPopup()" aria-label="Close past event popup">X</button>
        <h2 id="popup-event-name">Event Name</h2>
        <br>
        <p><strong>Type:</strong> <span id="popup-event-type"></span></p>
        <p><strong>Location:</strong> <span id="popup-event-location"></span></p>
        <p><strong>Date:</strong> <span id="popup-event-date"></span></p>
        <p><strong>Visibility:</strong> <span id="popup-event-visibility"></span></p>
        <p><strong>Ticket: </strong><span id="popup-event-ticket"></span></p>
        <p><strong>Details: </strong><span id="popup-event-details"></span></p>
        <p><strong>Collected Amount:</strong><span id="popup-event-collected-amount"></span></p>
        <p><strong>Vender Expense: </strong><span id="popup-evnet-vender-expense"></span></p>
        <p><strong>Venue Cost:</strong><span id="popup-event-venue-cost"></span></p>
        <p><strong>Total Ticket Sale:</strong><span id="popup-evnet-ticket-sale"></span></p>
        <label for="payDue">Pay Due</label>
        <input type="number" id="payDue" min="0" placeholder="Enter Due Amount">
        <label for="totalLoss">Loss</label>
        <input type="number" id="totalLoss" min="0" placeholder="total loss">
        
        <div class="popup-actions">
            <button>Update</button>
            <button class="cancel-btn" type="button" onclick="">Display</button> <!-- make it toggle-->
            <button type="button" onclick="">Hide</button>
        </div>
        </div>

      <script src="js/admin.js"></script>
  </body>
</html>
